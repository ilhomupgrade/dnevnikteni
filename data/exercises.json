      "main": {
        "steps": [
          {
            "text": "Представьте портрет своей души. Какие цвета вы видите?"
          },
          {
            "text": "Какое выражение у этого внутреннего 'лица'?"
          },
          {
            "text": "Что скрыто в глубине? Какие части хочется затушевать?"
          }
        ]
      },
      "evening": {
        "text": "Что я открыл в себе сегодня такого, чего не замечал раньше?"
      }
    },
